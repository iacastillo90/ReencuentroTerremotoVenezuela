# ==========================================
# AYUDAVE - VARIABLES DE ENTORNO CENTRALIZADAS
# ==========================================

# 1. Base de Datos (MongoDB)
MONGO_URI=mongodb://127.0.0.1:27017/reencuentro

# 2. Caché y Colas (Redis)
REDIS_URL=redis://127.0.0.1:6379

# 3. Almacenamiento Seguro de Fotos/Videos (MinIO)
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ayudave-media

# 4. Orquestación de Inteligencia Artificial
# Opciones soportadas: anthropic, openai, gemini
AI_PROVIDER=anthropic

# Descomenta y llena la llave del proveedor que quieras usar:
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# 5. Seguridad de Servidor
PORT=4000
# Genera valores propios y NO los subas al repositorio (repo publico).
# Ej: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=
PARTNER_API_KEY=
# Secreto compartido para los webhooks de ingesta de n8n (WhatsApp/Telegram).
# El backend rechaza todos los webhooks si no esta definido (header: x-webhook-api-key).
WEBHOOK_API_KEY=

# 6. Seguridad Reforzada (Fase 2)
# Obligatorio en produccion. Genera uno con:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
# Coincidencia EXACTA por origen (esquema incluido): lista cada origen de produccion,
# p. ej. https://app.midominio.com,https://www.midominio.com
CORS_ORIGINS=http://localhost:5173,http://localhost:4000
CSP_ENFORCE=false

# 7. Modo Desarrollo (Fase 3)
DEV_MODE=false
VITE_GOOGLE_CLIENT_ID=
