# ==========================================
# AYUDAVE - VARIABLES DE ENTORNO CENTRALIZADAS
# ==========================================

# 1. Base de Datos (MongoDB)
MONGO_URI=mongodb://127.0.0.1:27017/ayudave

# 2. Caché y Colas (Redis)
REDIS_URL=redis://127.0.0.1:6379

# 3. Almacenamiento Seguro de Fotos/Videos (MinIO)
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ayudave-media

# 4. Orquestación de Inteligencia Artificial
# Opciones soportadas: anthropic, openai, gemini
AI_PROVIDER=anthropic

# Descomenta y llena la llave del proveedor que quieras usar:
# ANTHROPIC_API_KEY=sk-ant-api03-xxxx
# OPENAI_API_KEY=sk-xxxx
# GEMINI_API_KEY=AIzaSy-xxxx

# 5. Seguridad de Servidor
PORT=4000
ADMIN_API_KEY=super-secret-admin-key-2026
PARTNER_API_KEY=partner-integration-key-2026
