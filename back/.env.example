# ==========================================
# AYUDAVE - VARIABLES DE ENTORNO CENTRALIZADAS
# ==========================================

# 1. Base de Datos (MongoDB)
MONGO_URI=mongodb://127.0.0.1:27017/ayudave

# 2. Caché y Colas (Redis)
REDIS_URL=redis://127.0.0.1:6379

# 3. Almacenamiento Seguro de Fotos/Videos (MinIO)
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ayudave-media

# 4. Orquestación de Inteligencia Artificial
# Opciones soportadas: anthropic, openai, gemini
AI_PROVIDER=anthropic

# Descomenta y llena la llave del proveedor que quieras usar:
# ANTHROPIC_API_KEY=sk-ant-api03-xxxx
# OPENAI_API_KEY=sk-xxxx
# GEMINI_API_KEY=AIzaSy-xxxx

# 5. Seguridad de Servidor
PORT=4000
# OBLIGATORIO en producción: si falta, el servidor aborta. Usa un valor largo y aleatorio.
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
ADMIN_API_KEY=REDACTED
# Clave para integraciones de socios (rutas /api/partners). Si falta, se niega todo acceso de partners.
# PARTNER_API_KEY=

# 6. CORS / Frontend
# Orígenes permitidos para CORS en producción (separa varios con coma). Ej: https://tu-app.vercel.app
# En desarrollo, si se deja vacío, se permiten localhost:5173/4173.
# FRONTEND_URL=https://tu-app.vercel.app

# 7. Banderas de DESARROLLO (NO activar en producción)
# Permite el "login de desarrollo" sin verificar la firma del token de Google (solo si NODE_ENV!=production).
# ALLOW_DEV_LOGIN=false
# Permite que los jobs de ingesta inserten datos SIMULADOS (marcados isSimulated) cuando la fuente externa
# no responde. Por defecto desactivado para no mostrar personas ficticias como reales.
# ALLOW_MOCK_DATA=false

# 8. Identificador del cliente de Google OAuth (compartido con el frontend, prefijo VITE_)
# VITE_GOOGLE_CLIENT_ID=
